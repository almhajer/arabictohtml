    "prefix": [
      "صفحة",
      "قالب html"
    ],
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"ar\" dir=\"rtl\">",
      "<head>",
      "  <meta charset=\"UTF-8\" />",

        "scope": "javascript,js"
    },
    "js:fetch-async": {
        "prefix": "fetch",
        "body": [
            "// قالب fetch باستخدام async/await",
            "async function ${1:fetchData}(${2:url}) {",
            "  try {",
            "    const res = await fetch(${2:url});",
            "    if (!res.ok) throw new Error(res.statusText);",
            "    const data = await res.json();",
            "    return data;",
            "  } catch (err) {",
            "    console.error(err);",
            "    throw err;",
            "  }",
            "}"
        ],
        "description": "قالب fetch مع معالجة الأخطاء باستخدام async/await",
        "scope": "javascript,js"
    },
    "js:debounce": {
        "prefix": "debounce",
        "body": [
            "// دالة debounce للاستخدام مع input/resize",
            "function ${1:debounce}(fn, wait = ${2:250}) {",
            "  let t;",
            "  return (...args) => {",
            "    clearTimeout(t);",
            "    t = setTimeout(() => fn.apply(this, args), wait);",
            "  };",
            "}"
        ],
        "description": "إنشاء غلاف debounce لوظائف الإدخال أو تغيير الحجم",
        "scope": "javascript,js"
    },

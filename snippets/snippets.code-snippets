            "  display: flex;",
            "  flex-direction: ${1:row}; /* row | column */",
            "  justify-content: ${2:space-between}; /* flex-start | center | space-between */",
            "  align-items: ${3:center}; /* flex-start | center | stretch */",
            "  gap: ${4:16px};",
            "}"
        ],
        "description": "إنشاء حاوية CSS مرنة مع خيارات محاذاة شائعة",
        "scope": "css"
    },
    "css:grid-layout": {
        "prefix": "grid",
        "body": [
            "/* شبكة CSS استجابة */",
            ".grid {",
            "  display: grid;",
            "  grid-template-columns: repeat(${1:3}, 1fr);",
            "  gap: ${2:16px};",
            "}",
            "@media (max-width: ${3:768px}) {",

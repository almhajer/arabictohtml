            "  width: 20px;",
            "  height: 20px;",
            "  border-radius: 50%;",
            "  background: #007BFF;",
            "  cursor: pointer;",
            "}",
            "</style>",
            "",
            "<script>",
            "document.getElementById('${1:slider}').addEventListener('input', (e) => {",

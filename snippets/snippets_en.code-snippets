{
  "page:html": {
    "prefix": [
      "html page",
      "new html page"
    ],
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"en\" dir=\"ltr\">",
      "<head>",
      "  <meta charset=\"UTF-8\" />",
      "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />",
      "  <title>${1:New Page}</title>",
      "</head>",
      "<body>",
      "  ${0}",
      "</body>",
      "</html>"
    ],
    "description": "Create a full HTML page template",
    "scope": "html"
  },
  "link:css": {
    "prefix": [
      "link css",
      "stylesheet link"
    ],
    "body": [
      "<link rel=\"stylesheet\" href=\"${1:styles.css}\" />"
    ],
    "description": "Link an external CSS file",
    "scope": "html"
  },
  "script:defer": {
    "prefix": [
      "script defer",
      "external js"
    ],
    "body": [
      "<script src=\"${1:app.js}\" defer></script>"
    ],
    "description": "Add external JavaScript file with defer",
    "scope": "html"
  },
  "meta:description": {
    "prefix": [
      "meta description",
      "page description"
    ],
    "body": [
      "<meta name=\"description\" content=\"${1:Page description}\" />"
    ],
    "description": "Add page description meta tag",
    "scope": "html"
  },
  "css:variables": {
    "prefix": [
      "css vars",
      "css variables"
    ],
    "body": [
      ":root {",
      "  --${1:primary}: ${2:#0ea5e9};",
      "  --${3:text}: ${4:#111827};",
      "}",
      "",
      "${5:body} {",
      "  color: var(--${3:text});",
      "}"
    ],
    "description": "Define and use CSS custom properties",
    "scope": "css,scss,less,html"
  },
  "css:flex-center": {
    "prefix": [
      "flex center",
      "css flex center"
    ],
    "body": [
      "display: flex;",
      "align-items: center;",
      "justify-content: center;"
    ],
    "description": "Center content using Flexbox",
    "scope": "css,scss,less,html"

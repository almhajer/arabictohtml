  "css:grid-auto": {
    "prefix": [
      "grid auto",
      "css grid auto"
    ],
    "body": [
      "display: grid;",
      "grid-template-columns: repeat(auto-fit, minmax(${1:240px}, 1fr));",
      "gap: ${2:1rem};"
    ],
    "description": "Responsive CSS grid template",
    "scope": "css,scss,less,html"
  },
